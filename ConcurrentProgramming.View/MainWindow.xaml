<Window x:Class="ConcurrentProgramming.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConcurrentProgramming.View"
        mc:Ignorable="d"
        Title="Programowanie współbieżne kulki" Height="450" Width="800"
        ResizeMode="CanMinimize">
    <Canvas x:Name="ball_container">
        <Ellipse 
            Height="25"
            Width="25"
            Fill="Black"
            Canvas.Left="{Binding Y}"
            Canvas.Top="{Binding X}"
            x:Name="ball_template"
            Visibility="Hidden"
        />
    </Canvas>
</Window>
